# Browser application
VITE_GOOGLE_CLIENT_ID=replace-with-google-oauth-client-id
VITE_SYNC_WORKER_URL=https://sync.example.com
VITE_PUSH_NOTIFICATIONS_ENABLED=false

# Optional DebugBundle browser reporting
VITE_DEBUGBUNDLE_PROJECT_TOKEN=replace-with-debugbundle-project-token
VITE_DEBUGBUNDLE_ENVIRONMENT=development

# Optional local agent bridge defaults
TASKTIME_APP_URL=http://127.0.0.1:3101
TASKTIME_AGENT_BRIDGE_HOST=127.0.0.1
TASKTIME_AGENT_BRIDGE_PORT=0
TASKTIME_AGENT_BRIDGE_PATH=/tasktime-agent
TASKTIME_AGENT_BRIDGE_ORIGINS=http://127.0.0.1:3101,http://localhost:3101
TASKTIME_AGENT_BRIDGE_SCOPES=read,write,billing,export,email,navigation
TASKTIME_AGENT_BRIDGE_PAIRING_TTL_MS=300000
TASKTIME_AGENT_BRIDGE_SESSION_TTL_MS=86400000
TASKTIME_AGENT_BRIDGE_COMMAND_TIMEOUT_MS=30000
TASKTIME_AGENT_BRIDGE_TOOL_RATE_LIMIT=120
TASKTIME_AGENT_BRIDGE_TOOL_RATE_WINDOW_MS=60000
TASKTIME_AGENT_BRIDGE_STATUS_FILE=
TASKTIME_AGENT_ID=tasktime.agent.local
TASKTIME_AGENT_LABEL=Local agent

# Optional browser/E2E overrides
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3101
PLAYWRIGHT_PWA_BASE_URL=http://127.0.0.1:4173
PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=
TASKTIME_AGENT_LIVE_BASE_URL=http://127.0.0.1:3101
TASKTIME_AGENT_LIVE_HOST=127.0.0.1
TASKTIME_AGENT_LIVE_PORT=3101
TASKTIME_AGENT_LIVE_START_APP=1

# Never place production secrets, Worker private configuration, refresh tokens,
# provider account identifiers, KV/D1 identifiers, or signing keys in this file.
