{
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@/*": ["./src/*"]
        },
        "lib": ["ES2020", "DOM"],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "jsx": "react-jsx",
        "allowJs": true,
        "checkJs": false,
        "isolatedModules": true,
        "noEmit": true
    },
    "include": ["src", "vitest.config.js"],
    "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx"]
}
