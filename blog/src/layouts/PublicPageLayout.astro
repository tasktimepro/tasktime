---
import '../styles/global.css';
import {
    DEFAULT_SOCIAL_IMAGE,
    DEFAULT_SOCIAL_IMAGE_ALT,
    SITE_DESCRIPTION,
    SITE_NAME,
    SITE_URL,
    TASKTIME_SOCIAL_URL,
    toAbsoluteUrl,
    toCanonicalUrl,
    toJsonLd,
} from '../config/site.js';
import { THEME_INIT_SCRIPT, THEME_TOGGLE_SCRIPT } from '../config/theme.js';

const {
    pageKey,
    title,
    summary,
    lastUpdated,
    lastUpdatedIso,
    highlights = [],
    canonicalPath = Astro.url.pathname,
    socialTitle = `${title} | TaskTime Pro`,
    socialDescription = summary,
    socialImage = DEFAULT_SOCIAL_IMAGE,
    socialImageAlt = DEFAULT_SOCIAL_IMAGE_ALT,
} = Astro.props;

const siteUrl = Astro.site ?? new URL(SITE_URL);
const canonicalUrl = toCanonicalUrl(canonicalPath, siteUrl);
const pageTitle = `${title} | TaskTime Pro`;
const socialImageUrl = new URL(socialImage, SITE_URL).toString();
const currentYear = new Date().getFullYear();
const organizationId = toAbsoluteUrl('/#organization', SITE_URL);
const websiteId = toAbsoluteUrl('/#website', SITE_URL);
const webpageId = `${canonicalUrl}#webpage`;
const breadcrumbSchemaId = `${canonicalUrl}#breadcrumb`;
const navItems = [
    {
        href: '/privacy/',
        key: 'privacy',
        label: 'Privacy Policy',
    },
    {
        href: '/terms/',
        key: 'terms',
        label: 'Terms & Conditions',
    },
    {
        href: '/contact/',
        key: 'contact',
        label: 'Contact',
    },
];
const structuredData = {
    '@context': 'https://schema.org',
    '@graph': [
        {
            '@type': 'Organization',
            '@id': organizationId,
            name: SITE_NAME,
            url: toCanonicalUrl('/', siteUrl),
            logo: {
                '@type': 'ImageObject',
                url: toAbsoluteUrl(DEFAULT_SOCIAL_IMAGE, SITE_URL),
            },
            sameAs: [TASKTIME_SOCIAL_URL],
        },
        {
            '@type': 'WebSite',
            '@id': websiteId,
            name: SITE_NAME,
            url: toCanonicalUrl('/', siteUrl),
            description: SITE_DESCRIPTION,
            publisher: {
                '@id': organizationId,
            },
        },
        {
            '@type': 'WebPage',
            '@id': webpageId,
            url: canonicalUrl,
            name: pageTitle,
            description: summary,
            dateModified: lastUpdatedIso,
            isPartOf: {
                '@id': websiteId,
            },
            breadcrumb: {
                '@id': breadcrumbSchemaId,
            },
        },
        {
            '@type': 'BreadcrumbList',
            '@id': breadcrumbSchemaId,
            itemListElement: [
                {
                    '@type': 'ListItem',
                    position: 1,
                    name: SITE_NAME,
                    item: toCanonicalUrl('/', siteUrl),
                },
                {
                    '@type': 'ListItem',
                    position: 2,
                    name: title,
                    item: canonicalUrl,
                },
            ],
        },
    ],
};
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <script is:inline set:html={THEME_INIT_SCRIPT}></script>
        <title>{pageTitle}</title>
        <meta name="description" content={summary} />
        <meta name="robots" content="index,follow" />
        <link rel="canonical" href={canonicalUrl} />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
        <link rel="shortcut icon" href="/favicon.ico" />
        <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
        <meta property="og:type" content="website" />
        <meta property="og:title" content={socialTitle} />
        <meta property="og:description" content={socialDescription} />
        <meta property="og:url" content={canonicalUrl} />
        <meta property="og:image" content={socialImageUrl} />
        <meta property="og:image:alt" content={socialImageAlt} />
        <meta property="og:site_name" content="TaskTime Pro" />
        <meta property="og:locale" content="en_US" />
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={socialTitle} />
        <meta name="twitter:description" content={socialDescription} />
        <meta name="twitter:image" content={socialImageUrl} />
        <meta name="twitter:image:alt" content={socialImageAlt} />
        <script type="application/ld+json" set:html={toJsonLd(structuredData)}></script>
    </head>
    <body>
        <div class="page-shell">
            <header class="site-header">
                <div class="site-header-top">
                    <a class="brand" href="/">
                        <img class="brand-mark" src="/favicon.svg" alt="" aria-hidden="true" />
                        <span class="brand-label">TaskTime Pro</span>
                    </a>
                    <div class="site-header-controls">
                        <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Toggle color theme">
                            <span class="sr-only">Toggle color theme</span>
                            <svg class="theme-toggle__icon theme-toggle__icon--moon" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2">
                                <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9"></path>
                            </svg>
                            <svg class="theme-toggle__icon theme-toggle__icon--sun" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2">
                                <circle cx="12" cy="12" r="4"></circle>
                                <path d="M12 2v2"></path>
                                <path d="M12 20v2"></path>
                                <path d="m4.93 4.93 1.41 1.41"></path>
                                <path d="m17.66 17.66 1.41 1.41"></path>
                                <path d="M2 12h2"></path>
                                <path d="M20 12h2"></path>
                                <path d="m6.34 17.66-1.41 1.41"></path>
                                <path d="m19.07 4.93-1.41 1.41"></path>
                            </svg>
                        </button>
                    </div>
                </div>
                <nav class="site-nav" aria-label="Primary">
                    <div class="site-nav-links">
                        <a href="/agents/">Agent Docs</a>
                        <a href="/blog/">Blog</a>
                    </div>
                    <div class="site-nav-actions">
                        <a href="/" class="cta-button">Open App</a>
                    </div>
                </nav>
            </header>

            <main class="site-main public-page-shell">
                <div class="public-page-grid">
                    <aside class="public-page-sidebar">
                        <section class="public-page-panel">
                            <h2>Public pages</h2>
                            <nav class="public-page-nav" aria-label="Public pages">
                                {navItems.map((item) => (
                                    <a
                                        href={item.href}
                                        aria-current={item.key === pageKey ? 'page' : undefined}
                                        class:list={{
                                            'is-active': item.key === pageKey,
                                        }}
                                    >
                                        {item.label}
                                    </a>
                                ))}
                            </nav>
                        </section>

                        <section class="public-page-panel">
                            <h2>At a glance</h2>
                            <p class="public-page-updated">Last updated {lastUpdated}</p>
                            <ul class="public-page-highlights">
                                {highlights.map((item) => (
                                    <li>{item}</li>
                                ))}
                            </ul>
                        </section>
                    </aside>

                    <article class="public-page-card">
                        <header class="article-header">
                            <h1>{title}</h1>
                            <p class="article-summary">{summary}</p>
                        </header>

                        <div class="public-page-copy">
                            <slot />
                        </div>
                    </article>
                </div>
            </main>

            <footer class="site-footer">
                <p class="footer-copyright">
                    <span class="footer-copyright-icon" aria-hidden="true">&copy;</span>
                    <span>{currentYear} TaskTime Pro. All rights reserved.</span>
                </p>
                <div class="footer-links">
                    <a class="footer-icon-link" href="https://x.com/tasktimepro" target="_blank" rel="noreferrer noopener" aria-label="TaskTime Pro on X">
                        <img src="/x.svg" alt="" aria-hidden="true" width="16" height="16" loading="lazy" />
                    </a>
                    <a href="/agents/">Agent Docs</a>
                    <a href="/blog/">Blog</a>
                    <a href="/contact/">Contact</a>
                    <a href="/privacy/">Privacy</a>
                    <a href="/terms/">Terms</a>
                    <a href="/blog/rss.xml">RSS</a>
                </div>
            </footer>
        </div>
        <script is:inline set:html={THEME_TOGGLE_SCRIPT}></script>
    </body>
</html>
