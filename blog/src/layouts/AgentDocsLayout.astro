---
import '../styles/global.css';
import {
    AGENT_DISCOVERY_LINKS,
    AGENT_DOCS_KEYWORDS,
    AGENT_DOCS_LAST_UPDATED,
    AGENT_DOCS_NAV_ITEMS,
} from '../config/agents.js';
import {
    DEFAULT_SOCIAL_IMAGE,
    DEFAULT_SOCIAL_IMAGE_ALT,
    SITE_DESCRIPTION,
    SITE_NAME,
    SITE_URL,
    TASKTIME_SOCIAL_URL,
    toAbsoluteUrl,
    toCanonicalUrl,
    toJsonLd,
} from '../config/site.js';
import { THEME_INIT_SCRIPT, THEME_TOGGLE_SCRIPT } from '../config/theme.js';

const {
    pageKey,
    title,
    description,
    canonicalPath = Astro.url.pathname,
    highlights = [],
    keywords = AGENT_DOCS_KEYWORDS,
    socialTitle = `${title} | TaskTime Pro Agent Docs`,
    socialDescription = description,
    socialImage = DEFAULT_SOCIAL_IMAGE,
    socialImageAlt = DEFAULT_SOCIAL_IMAGE_ALT,
} = Astro.props;

const siteUrl = Astro.site ?? new URL(SITE_URL);
const canonicalUrl = toCanonicalUrl(canonicalPath, siteUrl);
const pageTitle = `${title} | TaskTime Pro Agent Docs`;
const socialImageUrl = new URL(socialImage, SITE_URL).toString();
const keywordsContent = keywords.join(', ');
const currentYear = new Date().getFullYear();
const organizationId = toAbsoluteUrl('/#organization', SITE_URL);
const websiteId = toAbsoluteUrl('/#website', SITE_URL);
const webpageId = `${canonicalUrl}#webpage`;
const breadcrumbId = `${canonicalUrl}#breadcrumb`;
const docsId = `${toCanonicalUrl('/agents/', siteUrl)}#agent-docs`;
const structuredData = {
    '@context': 'https://schema.org',
    '@graph': [
        {
            '@type': 'Organization',
            '@id': organizationId,
            name: SITE_NAME,
            url: toCanonicalUrl('/', siteUrl),
            logo: {
                '@type': 'ImageObject',
                url: toAbsoluteUrl(DEFAULT_SOCIAL_IMAGE, SITE_URL),
            },
            sameAs: [TASKTIME_SOCIAL_URL],
        },
        {
            '@type': 'WebSite',
            '@id': websiteId,
            name: SITE_NAME,
            url: toCanonicalUrl('/', siteUrl),
            description: SITE_DESCRIPTION,
            publisher: {
                '@id': organizationId,
            },
        },
        {
            '@type': 'TechArticle',
            '@id': webpageId,
            url: canonicalUrl,
            headline: title,
            description,
            dateModified: AGENT_DOCS_LAST_UPDATED,
            isPartOf: {
                '@id': docsId,
            },
            publisher: {
                '@id': organizationId,
            },
            about: [
                'Model Context Protocol',
                'local-first software',
                'AI agent integration',
                'time tracking',
                'freelance invoicing',
            ],
            breadcrumb: {
                '@id': breadcrumbId,
            },
        },
        {
            '@type': 'CreativeWorkSeries',
            '@id': docsId,
            name: 'TaskTime Pro Agent Docs',
            url: toCanonicalUrl('/agents/', siteUrl),
            description: 'TaskTime Pro local AI agent and MCP bridge documentation.',
            publisher: {
                '@id': organizationId,
            },
        },
        {
            '@type': 'BreadcrumbList',
            '@id': breadcrumbId,
            itemListElement: [
                {
                    '@type': 'ListItem',
                    position: 1,
                    name: SITE_NAME,
                    item: toCanonicalUrl('/', siteUrl),
                },
                {
                    '@type': 'ListItem',
                    position: 2,
                    name: 'Agent Docs',
                    item: toCanonicalUrl('/agents/', siteUrl),
                },
                {
                    '@type': 'ListItem',
                    position: 3,
                    name: title,
                    item: canonicalUrl,
                },
            ],
        },
    ],
};
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <script is:inline set:html={THEME_INIT_SCRIPT}></script>
        <title>{pageTitle}</title>
        <meta name="description" content={description} />
        <meta name="robots" content="index,follow" />
        <meta name="keywords" content={keywordsContent} />
        <link rel="canonical" href={canonicalUrl} />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
        <link rel="shortcut icon" href="/favicon.ico" />
        <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
        <link rel="alternate" type="application/rss+xml" title="TaskTime Pro Blog" href="/blog/rss.xml" />
        <link rel="alternate" type="text/plain" title="TaskTime Pro llms.txt" href="/llms.txt" />
        <link rel="alternate" type="application/json" title="TaskTime Pro MCP tools" href="/agents/mcp-tools.json" />
        <meta property="og:type" content="article" />
        <meta property="og:title" content={socialTitle} />
        <meta property="og:description" content={socialDescription} />
        <meta property="og:url" content={canonicalUrl} />
        <meta property="og:image" content={socialImageUrl} />
        <meta property="og:image:alt" content={socialImageAlt} />
        <meta property="og:site_name" content="TaskTime Pro" />
        <meta property="og:locale" content="en_US" />
        <meta property="article:modified_time" content={AGENT_DOCS_LAST_UPDATED} />
        <meta property="article:section" content="Agent Documentation" />
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={socialTitle} />
        <meta name="twitter:description" content={socialDescription} />
        <meta name="twitter:image" content={socialImageUrl} />
        <meta name="twitter:image:alt" content={socialImageAlt} />
        <script type="application/ld+json" set:html={toJsonLd(structuredData)}></script>
    </head>
    <body>
        <div class="page-shell">
            <header class="site-header">
                <div class="site-header-top">
                    <a class="brand" href="/agents/">
                        <img class="brand-mark" src="/favicon.svg" alt="" aria-hidden="true" />
                        <span class="brand-label">TaskTime Pro Agent Docs</span>
                    </a>
                    <div class="site-header-controls">
                        <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Toggle color theme">
                            <span class="sr-only">Toggle color theme</span>
                            <svg class="theme-toggle__icon theme-toggle__icon--moon" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2">
                                <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9"></path>
                            </svg>
                            <svg class="theme-toggle__icon theme-toggle__icon--sun" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2">
                                <circle cx="12" cy="12" r="4"></circle>
                                <path d="M12 2v2"></path>
                                <path d="M12 20v2"></path>
                                <path d="m4.93 4.93 1.41 1.41"></path>
                                <path d="m17.66 17.66 1.41 1.41"></path>
                                <path d="M2 12h2"></path>
                                <path d="M20 12h2"></path>
                                <path d="m6.34 17.66-1.41 1.41"></path>
                                <path d="m19.07 4.93-1.41 1.41"></path>
                            </svg>
                        </button>
                    </div>
                </div>
                <nav class="site-nav" aria-label="Primary">
                    <div class="site-nav-links">
                        <a href="/blog/">Blog</a>
                    </div>
                    <div class="site-nav-actions">
                        <a href="/" class="cta-button">Open App</a>
                    </div>
                </nav>
            </header>

            <main class="site-main agent-docs-shell">
                <div class="agent-docs-grid">
                    <aside class="agent-docs-sidebar">
                        <section class="agent-docs-panel">
                            <h2>Agent docs</h2>
                            <nav class="agent-docs-nav" aria-label="Agent documentation">
                                {AGENT_DOCS_NAV_ITEMS.map((item) => (
                                    <a
                                        href={item.href}
                                        aria-current={item.key === pageKey ? 'page' : undefined}
                                        class:list={{
                                            'is-active': item.key === pageKey,
                                        }}
                                    >
                                        <span>{item.label}</span>
                                        <small>{item.summary}</small>
                                    </a>
                                ))}
                            </nav>
                        </section>

                        <section class="agent-docs-panel">
                            <h2>Discovery files</h2>
                            <ul class="agent-discovery-list">
                                {AGENT_DISCOVERY_LINKS.map((link) => (
                                    <li>
                                        <a href={link.href}>{link.label}</a>
                                        <p>{link.summary}</p>
                                    </li>
                                ))}
                            </ul>
                        </section>

                        {highlights.length > 0 && (
                            <section class="agent-docs-panel">
                                <h2>At a glance</h2>
                                <p class="agent-docs-updated">Updated {AGENT_DOCS_LAST_UPDATED}</p>
                                <ul class="agent-highlight-list">
                                    {highlights.map((item) => (
                                        <li>{item}</li>
                                    ))}
                                </ul>
                            </section>
                        )}
                    </aside>

                    <article class="agent-docs-content">
                        <header class="agent-docs-header">
                            <p class="eyebrow">TaskTime Pro local agent bridge</p>
                            <h1>{title}</h1>
                            <p>{description}</p>
                        </header>

                        <div class="agent-docs-copy">
                            <slot />
                        </div>
                    </article>
                </div>
            </main>

            <footer class="site-footer">
                <p class="footer-copyright">
                    <span class="footer-copyright-icon" aria-hidden="true">&copy;</span>
                    <span>{currentYear} TaskTime Pro. All rights reserved.</span>
                </p>
                <div class="footer-links">
                    <a class="footer-icon-link" href="https://x.com/tasktimepro" target="_blank" rel="noreferrer noopener" aria-label="TaskTime Pro on X">
                        <img src="/x.svg" alt="" aria-hidden="true" width="16" height="16" loading="lazy" />
                    </a>
                    <a href="/agents/">Agent Docs</a>
                    <a href="/blog/">Blog</a>
                    <a href="/contact/">Contact</a>
                    <a href="/privacy/">Privacy</a>
                    <a href="/terms/">Terms</a>
                    <a href="/blog/rss.xml">RSS</a>
                </div>
            </footer>
        </div>
        <script is:inline set:html={THEME_TOGGLE_SCRIPT}></script>
    </body>
</html>
