---
import BlogPostList from '../../components/BlogPostList.astro';
import BlogLayout from '../../layouts/BlogLayout.astro';
import {
    BLOG_PAGE_SIZE,
    getBlogPageCount,
    getBlogPostsForPage,
    getPublishedBlogPosts,
} from '../../lib/blog.js';

const posts = await getPublishedBlogPosts();
const totalPages = getBlogPageCount(posts, BLOG_PAGE_SIZE);
const pagePosts = getBlogPostsForPage(posts, 1, BLOG_PAGE_SIZE);
---

<BlogLayout
    title="TaskTime Pro Blog"
    description="Tips, guides, and honest takes on privacy-first freelancing — from invoicing and expense tracking to time management and staying in control of your data."
    pageType="website"
>
    <section class="hero">
        <p class="eyebrow">The TaskTime Pro Blog</p>
        <h1>Our Blog</h1>
        <p class="hero-copy">
            Tips, comparisons, and honest guides for freelancers who want to track time, manage expenses,
            send invoices, and keep their data private — all without the usual SaaS headaches.
        </p>
    </section>

    <BlogPostList posts={pagePosts} currentPage={1} totalPages={totalPages} />
</BlogLayout>
