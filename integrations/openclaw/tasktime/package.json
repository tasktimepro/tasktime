{
  "name": "@tasktimepro/openclaw",
  "version": "1.0.0",
  "description": "First-party native OpenClaw plugin for TaskTime Pro's free, open-source, local-first work manager.",
  "type": "module",
  "main": "./dist/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tasktimepro/tasktime.git",
    "directory": "integrations/openclaw/tasktime"
  },
  "files": [
    ".codex-plugin/",
    ".mcp.json",
    "dist/",
    "LICENSE",
    "LICENSE.agent-bridge",
    "README.md",
    "openclaw.plugin.json",
    "scripts/",
    "skills/",
    "vendor/"
  ],
  "keywords": [
    "tasktime",
    "openclaw",
    "project-management",
    "task-management",
    "ai-agent",
    "time-tracking",
    "invoicing",
    "expenses",
    "local-first",
    "open-source",
    "offline",
    "no-account"
  ],
  "homepage": "https://tasktime.pro/agents/openclaw/",
  "license": "(MIT-0 AND AGPL-3.0-only)",
  "publishConfig": {
    "access": "public"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "install": {
      "clawhubSpec": "clawhub:@tasktimepro/openclaw",
      "npmSpec": "@tasktimepro/openclaw",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.6.11"
    },
    "compat": {
      "pluginApi": ">=2026.6.11"
    }
  }
}
