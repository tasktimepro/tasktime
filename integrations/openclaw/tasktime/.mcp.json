{
  "mcpServers": {
    "tasktime": {
      "command": "node",
      "args": [
        "./scripts/run-tasktime-agent-bridge.mjs",
        "--app-url",
        "https://tasktime.pro",
        "--agent-id",
        "tasktime.agent.openclaw",
        "--agent-label",
        "OpenClaw on this device",
        "--session-ttl-ms",
        "86400000"
      ]
    }
  }
}
